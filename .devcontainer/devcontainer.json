// For format details, see https://aka.ms/devcontainer.json.
{
	"name": "Fedora",
	"build": {
		"dockerfile": "Dockerfile"
	},
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": "false",
			"username": "vscode",
			"userUid": "1000",
			"userGid": "1000",
			"upgradePackages": "false"
		}
	},
	"runArgs": [
		"--device=/dev/dri"
	],
	"containerEnv": {
		"RUN_IN_VSCODE_DEVCONTAINER": "true",
		"DISPLAY": "${localEnv:DISPLAY}"
	},
	"mounts": [],
	"postCreateCommand": "sudo dnf update -y && sudo dnf install -y rpmdevtools rpmlint jq && git submodule deinit -f --all && git submodule update --init --recursive --depth 1",
	"postStartCommand": "sudo dnf update -y && git pull && git submodule update --recursive --init --depth 1",
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"extensions": [
				"vadimcn.vscode-lldb",
				"tamasfe.even-better-toml",
				"redhat.vscode-yaml",
				"timonwong.shellcheck",
				"redhat.vscode-xml",
				"lumirelle.shell-format-rev",
				"esbenp.prettier-vscode",
				"ms-azuretools.vscode-containers",
				"RVSmartPorting.rpm-spec-ext",
				"IronGeek.vscode-env",
				"github.vscode-github-actions"
			]
		}
	}
}